# web/ demo — local env template. Copy to .env.local (git-ignored) and fill in.
#
# HubSpot Private App / Service Key token. The web backend reuses the SAME token
# the Claude Code demo uses. If you already set PRIVATE_APP_ACCESS_TOKEN as a
# system env var (setx), Next.js will pick it up and you can leave this blank.
PRIVATE_APP_ACCESS_TOKEN=

# LLM key for the judgment layer. Set ONE. Claude is preferred when present
# because its tool-calling natively tolerates HubSpot's MCP schemas. Groq and
# Gemini are lower-cost fallbacks and get an automatic schema patch. With none
# set, the backend runs in MOCK mode so the UI + CRM wiring still work.
#
# Claude (preferred): get one at https://console.anthropic.com — demo usage is a
# few cents at most.
ANTHROPIC_API_KEY=
#
# Gemini (free-tier fallback): https://aistudio.google.com/apikey — NOTE the free
# tier may report quota=0 until the project has a billing account attached.
GOOGLE_GENERATIVE_AI_API_KEY=
#
# Groq (free/low-cost fallback): https://console.groq.com/keys
GROQ_API_KEY=
