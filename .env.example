# HubSpot CRM Demo — environment template
# Copy this file to .env and fill in the real value. .env is git-ignored.
#
# HubSpot Private App access token. Used by @hubspot/mcp-server to read/write
# your CRM. Create it in HubSpot: Settings → Integrations → Private Apps.
# See README.md "Setup" for the exact scopes to enable.
#
# Format: starts with "pat-" (e.g. pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
PRIVATE_APP_ACCESS_TOKEN=pat-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
